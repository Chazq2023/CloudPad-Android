<?xml version="1.0" encoding="utf-8"?>
<!-- Selected/focused icon background with Pylux brand glow -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Focused via keyboard/D-pad -->
    <item android:state_activated="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="20dp" />
                    <solid android:color="?attr/pyluxAccentA50" />
                </shape>
            </item>
            <item android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp">
                <shape android:shape="rectangle">
                    <corners android:radius="18dp" />
                    <solid android:color="?attr/pyluxAccentA20" />
                    <stroke android:width="1.5dp" android:color="?attr/pyluxAccentA70" />
                </shape>
            </item>
        </layer-list>
    </item>
    <!-- Default selected state -->
    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="20dp" />
                    <solid android:color="?attr/pyluxAccentA30" />
                </shape>
            </item>
            <item android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp">
                <shape android:shape="rectangle">
                    <corners android:radius="18dp" />
                    <solid android:color="?attr/pyluxAccentA12" />
                    <stroke android:width="1dp" android:color="?attr/pyluxAccentA50" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
